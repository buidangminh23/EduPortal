# Cổng máy chủ
PORT=8080

# ── Whisper (phiên âm giọng nói → văn bản) ──
# Dựng faster-whisper-server hoặc whisper.cpp server nội bộ rồi đặt URL vào đây.
# Bỏ trống -> endpoint vẫn chạy nhưng trả bản mô phỏng.
WHISPER_URL=

# ── LLM tóm tắt (Qwen2.5 chạy nội bộ qua Ollama/vLLM) ──
# Ví dụ Ollama: http://localhost:11434/api/chat
# Bỏ trống -> trả bản mô phỏng.
LLM_URL=
LLM_MODEL=qwen2.5:14b

# ── Fallback API (tuỳ chọn, chỉ khi không có model nội bộ) ──
GEMINI_API_KEY=

# ── STUN/TURN cho WebRTC (client dùng khi thiết lập RTCPeerConnection) ──
# STUN miễn phí của Google đủ cho mạng thường; TURN cần khi vượt NAT/tường lửa.
# Xem README mục "STUN/TURN".
# TURN_URL=turn:your-turn-server:3478
# TURN_USER=
# TURN_PASS=
